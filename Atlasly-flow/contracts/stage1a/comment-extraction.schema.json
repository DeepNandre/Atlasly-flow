{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlasly/contracts/stage1a/comment-extraction.schema.json",
  "title": "Stage1ACommentExtraction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "letter_id",
    "document_id",
    "project_id",
    "extraction_version",
    "extractions",
    "summary"
  ],
  "properties": {
    "letter_id": {"type": "string", "format": "uuid"},
    "document_id": {"type": "string", "format": "uuid"},
    "project_id": {"type": "string", "format": "uuid"},
    "extraction_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "extractions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "comment_id",
          "raw_text",
          "discipline",
          "severity",
          "requested_action",
          "code_reference",
          "page_number",
          "citation",
          "confidence",
          "status"
        ],
        "properties": {
          "comment_id": {
            "type": "string",
            "pattern": "^cmt_[0-9]+_[a-f0-9]{12}$"
          },
          "raw_text": {"type": "string", "minLength": 20, "maxLength": 4000},
          "discipline": {
            "type": "string",
            "enum": [
              "structural",
              "electrical",
              "plumbing",
              "mechanical",
              "fire",
              "zoning",
              "civil",
              "architectural",
              "energy",
              "accessibility",
              "other"
            ]
          },
          "severity": {"type": "string", "enum": ["critical", "major", "minor", "info"]},
          "requested_action": {"type": "string", "minLength": 10, "maxLength": 1000},
          "code_reference": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "jurisdiction", "code_family", "valid_format"],
            "properties": {
              "value": {"type": "string"},
              "jurisdiction": {"type": "string"},
              "code_family": {
                "type": "string",
                "enum": ["IBC", "IRC", "IECC", "IFC", "NEC", "IPC", "IMC", "NFPA", "LOCAL", "UNKNOWN"]
              },
              "valid_format": {"type": "boolean"}
            }
          },
          "page_number": {"type": "integer", "minimum": 1},
          "citation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["quote", "char_start", "char_end"],
            "properties": {
              "quote": {"type": "string", "minLength": 8, "maxLength": 600},
              "char_start": {"type": "integer", "minimum": 0},
              "char_end": {"type": "integer", "minimum": 1}
            }
          },
          "confidence": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "raw_text",
              "discipline",
              "severity",
              "requested_action",
              "code_reference",
              "citation",
              "record"
            ],
            "properties": {
              "raw_text": {"type": "number", "minimum": 0, "maximum": 1},
              "discipline": {"type": "number", "minimum": 0, "maximum": 1},
              "severity": {"type": "number", "minimum": 0, "maximum": 1},
              "requested_action": {"type": "number", "minimum": 0, "maximum": 1},
              "code_reference": {"type": "number", "minimum": 0, "maximum": 1},
              "citation": {"type": "number", "minimum": 0, "maximum": 1},
              "record": {"type": "number", "minimum": 0, "maximum": 1}
            }
          },
          "status": {
            "type": "string",
            "enum": ["auto_accepted", "needs_review", "reviewed_corrected", "approved_snapshot"]
          },
          "normalization_flags": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "code_ref_unverified",
                "discipline_low_signal",
                "ocr_low_quality_page",
                "citation_span_fuzzy_match",
                "possible_duplicate"
              ]
            },
            "uniqueItems": true
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extraction_count", "avg_record_confidence", "requires_review_count"],
      "properties": {
        "extraction_count": {"type": "integer", "minimum": 0},
        "avg_record_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "requires_review_count": {"type": "integer", "minimum": 0}
      }
    }
  }
}
