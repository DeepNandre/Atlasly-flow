{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/stage1b/event-envelope-v1.json",
  "title": "Stage 1B Shared Event Envelope v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "organization_id",
    "aggregate_type",
    "aggregate_id",
    "occurred_at",
    "produced_by",
    "idempotency_key",
    "trace_id",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "minLength": 1 },
    "event_version": { "type": "integer", "const": 1 },
    "organization_id": { "type": "string", "format": "uuid" },
    "aggregate_type": { "type": "string", "minLength": 1 },
    "aggregate_id": { "type": "string", "minLength": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "produced_by": { "type": "string", "minLength": 1 },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" }
  },
  "additionalProperties": true
}
