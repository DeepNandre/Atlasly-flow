{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stage2/permit.status_changed.v1.schema.json",
  "title": "permit.status_changed v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "organization_id",
    "aggregate_type",
    "aggregate_id",
    "occurred_at",
    "produced_by",
    "idempotency_key",
    "trace_id",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "permit.status_changed" },
    "event_version": { "const": 1 },
    "organization_id": { "type": "string", "format": "uuid" },
    "aggregate_type": { "const": "permit" },
    "aggregate_id": { "type": "string", "format": "uuid" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "produced_by": { "type": "string", "minLength": 1 },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": ["permit_id", "old_status", "new_status", "source_event_id"],
      "properties": {
        "permit_id": { "type": "string", "format": "uuid" },
        "old_status": {
          "type": "string",
          "enum": ["submitted", "in_review", "corrections_required", "approved", "issued", "expired"]
        },
        "new_status": {
          "type": "string",
          "enum": ["submitted", "in_review", "corrections_required", "approved", "issued", "expired"]
        },
        "source_event_id": { "type": "string", "format": "uuid" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
