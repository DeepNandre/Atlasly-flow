{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stage2/permit.status_observed.v1.schema.json",
  "title": "permit.status_observed v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "organization_id",
    "aggregate_type",
    "aggregate_id",
    "occurred_at",
    "produced_by",
    "idempotency_key",
    "trace_id",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "permit.status_observed" },
    "event_version": { "const": 1 },
    "organization_id": { "type": "string", "format": "uuid" },
    "aggregate_type": { "const": "permit" },
    "aggregate_id": { "type": "string", "format": "uuid" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "produced_by": { "type": "string", "minLength": 1 },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": [
        "permit_id",
        "raw_status",
        "normalized_status",
        "source",
        "confidence",
        "observed_at"
      ],
      "properties": {
        "permit_id": { "type": "string", "format": "uuid" },
        "raw_status": { "type": "string", "minLength": 1 },
        "normalized_status": {
          "type": "string",
          "enum": ["submitted", "in_review", "corrections_required", "approved", "issued", "expired"]
        },
        "source": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "observed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
