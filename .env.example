# --- Core server ---
ATLASLY_HOST=0.0.0.0
ATLASLY_PORT=8080
ATLASLY_DATA_DIR=/data

# --- Stage 2: Shovels AHJ lookup ---
ATLASLY_SHOVELS_API_KEY=your_shovels_api_key_here
ATLASLY_SHOVELS_BASE_URL=https://api.shovels.ai

# --- Stage 2: live validation selector ---
ATLASLY_LIVE_VALIDATION_STRICT=0
ATLASLY_LIVE_CONNECTOR=accela_api
ATLASLY_LIVE_AHJ_ID=ca.san_jose.building
ATLASLY_LIVE_CREDENTIAL_REF=accela_prod_token
ATLASLY_LIVE_EXTERNAL_PERMIT_ID=

# --- Stage 2: connector secret for credential_ref=accela_prod_token ---
ATLASLY_CONNECTOR_SECRET_ACCELA_PROD_TOKEN=your_accela_token_here

# --- Stage 2: Accela connector config ---
ATLASLY_ACCELA_BASE_URL=https://apis.accela.com
ATLASLY_ACCELA_APP_ID=your_accela_app_id_here

# --- Stage 2: OpenGov connector config (only if using opengov_api) ---
ATLASLY_OPENGOV_BASE_URL=
ATLASLY_OPENGOV_STATUS_PATH=/permits/status

# --- Stage 3: Stripe sandbox ---
ATLASLY_STRIPE_SECRET_KEY=
ATLASLY_STRIPE_BASE_URL=https://api.stripe.com

# --- Stage 3: webhook signatures ---
ATLASLY_STAGE3_ENFORCE_SIGNATURES=0
ATLASLY_STAGE3_PROVIDER_WEBHOOK_SECRET=

# --- Pilot bootstrap identity ---
ATLASLY_BOOTSTRAP_ORG_SLUG=atlasly-pilot
ATLASLY_BOOTSTRAP_ORG_NAME=Atlasly Pilot Workspace
ATLASLY_BOOTSTRAP_OWNER_EMAIL=owner@atlasly.local
ATLASLY_BOOTSTRAP_ADMIN_EMAIL=admin@atlasly.local
ATLASLY_BOOTSTRAP_PM_EMAIL=pm@atlasly.local
ATLASLY_BOOTSTRAP_REVIEWER_EMAIL=reviewer@atlasly.local
ATLASLY_BOOTSTRAP_SUBCONTRACTOR_EMAIL=subcontractor@atlasly.local

# --- Stage 0.5 runtime boundary ---
ATLASLY_DEPLOYMENT_TIER=mvp
ATLASLY_STAGE05_RUNTIME_BACKEND=sqlite
ATLASLY_STAGE05_PERSISTENCE_READY=true
